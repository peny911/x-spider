X_SPIDER_DATA_DIR=.data
# 配置后优先连接已经通过 remote debugging 启动的 Chrome，例如 http://127.0.0.1:9222
X_SPIDER_CDP_ENDPOINT=
# 指定本地 Chrome 可执行文件路径时优先使用该路径；macOS 默认路径如下 /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
X_SPIDER_BROWSER_EXECUTABLE_PATH=
# 留空时使用 Playwright 自带 Chromium；如果 X 登录被限制，可尝试改为 chrome 使用本机 Chrome 渠道
X_SPIDER_BROWSER_CHANNEL=
# 建议保持 true，避免浏览器顶部出现 --no-sandbox 警告
X_SPIDER_CHROMIUM_SANDBOX=true
# 爬取完成后是否自动关闭 Playwright 启动的浏览器；CDP 模式不会主动关闭外部 Chrome
X_SPIDER_CLOSE_BROWSER_ON_FINISH=false
X_SPIDER_HEADLESS=false
X_SPIDER_VIEWPORT_WIDTH=1280
X_SPIDER_VIEWPORT_HEIGHT=900
X_SPIDER_REQUEST_TIMEOUT_SECONDS=45
X_SPIDER_NO_NEW_ROUND_LIMIT=8
X_SPIDER_SCROLL_STEP_MIN_PX=400
X_SPIDER_SCROLL_STEP_MAX_PX=800
X_SPIDER_SCROLL_PAUSE_MIN_SECONDS=1
X_SPIDER_SCROLL_PAUSE_MAX_SECONDS=2
X_SPIDER_SCROLL_STEPS_PER_ROUND=2
# 每条视频详情页捕获 video.twimg.com 网络请求的时间，单位秒
X_SPIDER_VIDEO_CAPTURE_SECONDS=10
